# App pages — nunca cachear
/app/*.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# Service worker — siempre revalidar
/sw.js
  Cache-Control: no-store

# Assets inmutables — cache agresivo
/js/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# JS en raíz (articles-ac.js, etc.) — revalidar siempre (se actualiza con auto-journal)
/*.js
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

# HTML siempre fresco
